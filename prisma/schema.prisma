// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// prisma/schema.prisma


// ==========================================
// 1. SKEMA NEXT-AUTH (USER MANAGEMENT)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  accounts      Account[]
  sessions      Session[]
  chats         Chat[]
  documents     Document[] // Persiapan untuk fitur RAG
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. SKEMA CHATBOT & MULTI-MODEL
// ==========================================

model Chat {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")
  userId    String
  // Menyimpan preferensi model untuk chat session ini (misal: "gpt-4o", "gemini-1.5-pro", "qwen")
  model     String   @default("gemini-1.5-pro") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId]) // Indexing untuk mempercepat query berdasarkan user
}

// Enum untuk menentukan siapa yang mengirim pesan
enum Role {
  user
  assistant
  system
  data
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      Role
  content   String   @db.Text
  
  // FIELD SUPER PENTING: Untuk fleksibilitas fitur masa depan
  // Bisa menyimpan URL gambar (Image Gen), Referensi Dokumen (RAG), atau metadata spesifik model
  metadata  Json?    
  
  createdAt DateTime @default(now())

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

// ==========================================
// 3. SKEMA DOKUMEN (PERSIAPAN RAG & FILE READING)
// ==========================================

model Document {
  id          String   @id @default(cuid())
  userId      String
  title       String
  fileUrl     String   // URL tempat file disimpan (misal: AWS S3, Vercel Blob, dll)
  fileType    String   // 'pdf', 'csv', 'txt'
  
  // Status pemrosesan file (misal: 'pending', 'embedded', 'failed')
  embedStatus String   @default("pending") 
  
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}